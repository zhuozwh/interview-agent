# 应用显示名称，会用于 FastAPI 文档标题。
APP_NAME=Interview Agent

# 当前运行环境的标识；Phase 0 默认使用 local。
APP_ENV=local

# Python 标准日志级别。
LOG_LEVEL=INFO

# 本地 SQLite 文件路径；程序真正连接数据库时才会创建文件。
DATABASE_PATH=data/interview_agent.db

# Markdown 只读数据源；相对路径按应用启动时的工作目录解释。
MARKDOWN_SOURCE_DIRECTORY=knowledge

# 允许读取的数据目录 JSON 数组；数据源及每个文件的规范化路径都必须位于其中。
ALLOWED_DATA_DIRECTORIES=["knowledge"]

# 单文件和一次加载的 UTF-8 原始字节上限，避免无界读取。
MARKDOWN_MAX_FILE_SIZE_BYTES=2097152
MARKDOWN_MAX_TOTAL_SIZE_BYTES=20971520
